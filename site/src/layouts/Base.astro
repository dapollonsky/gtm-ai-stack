---
import '../styles/global.css';
import entriesData from '../data/entries.json';

interface Props {
  title: string;
  description?: string;
  activeCategory?: string | null;
}

const {
  title,
  description = 'A curated, editorially-maintained map of AI-native tools and MCP plumbing for go-to-market teams.',
  activeCategory = null,
} = Astro.props;

const base = import.meta.env.BASE_URL; // e.g. "/gtm-ai-stack/" or "/"
const homeHref = base;
const repoUrl = 'https://github.com/dapollonsky/gtm-ai-stack';
const builtAt = entriesData.built_at;
const categories = entriesData.categories;

const catHref = (id: string) => {
  // Astro's BASE_URL always includes a trailing slash, so we join with a relative segment.
  return `${base.replace(/\/$/, '')}/category/${id}`;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' rx='3' fill='%231d4ed8'/%3E%3Ctext x='8' y='12' text-anchor='middle' font-family='-apple-system,Segoe UI,sans-serif' font-weight='700' font-size='10' fill='white'%3EG%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="wrap">
          <a class="brand" href={homeHref}>
            <span class="dot" aria-hidden="true"></span>GTM AI Stack
          </a>
          <nav class="cat-nav" aria-label="Categories">
            {categories.map((c) => (
              <a
                href={catHref(c.id)}
                aria-current={activeCategory === c.id ? 'page' : undefined}
              >
                {c.title}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <main>
        <div class="wrap">
          <slot />
        </div>
      </main>

      <footer class="site-footer">
        <div class="wrap">
          <span>
            <a href={repoUrl} rel="noopener noreferrer" target="_blank">
              github.com/dapollonsky/gtm-ai-stack
            </a>
            {' · '}
            Code <a href={`${repoUrl}/blob/main/LICENSE`} rel="noopener noreferrer" target="_blank">MIT</a>
            {' · '}
            Data <a href={`${repoUrl}/blob/main/LICENSE-DATA`} rel="noopener noreferrer" target="_blank">CC-BY-SA 4.0</a>
          </span>
          <span>built {builtAt}</span>
        </div>
      </footer>
    </div>
  </body>
</html>
